<mvc:View
    controllerName="sap.practice.practice.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <App>
        <Page title="Product Catalog" class="sapUiContentPadding">

            <VBox class="sapUiSmallMargin">

                <!-- 🔍 Search -->
                <SearchField 
                    placeholder="Search products..." 
                    liveChange=".onSearch"
                    width="100%" />

                <!-- 🎯 Filter by Brand -->
                <Select 
                    change=".onFilterCategory"
                    width="100%"
                    selectedKey="All">

                    <items>
                        <core:Item key="All" text="All Brands"/>
                        <core:Item key="Apple" text="Apple"/>
                        <core:Item key="Samsung" text="Samsung"/>
                        <core:Item key="Sony" text="Sony"/>
                        <core:Item key="Dell" text="Dell"/>
                        <core:Item key="Nike" text="Nike"/>
                        <core:Item key="Fossil" text="Fossil"/>
                    </items>

                </Select>

                <!-- 🔃 Sort -->
                <Button 
                    text="Sort by Price" 
                    press=".onSortByPrice"
                    type="Emphasized" />

                <!-- 📦 Product Table -->
                <Table 
                    id="yourTableId" 
                    items="{/products}" 
                    itemPress=".onItemPress"
                    inset="false">

                    <columns>
                        <Column><Text text="ID"/></Column>
                        <Column><Text text="Name"/></Column>
                        <Column><Text text="Brand"/></Column>
                        <Column><Text text="Price"/></Column>
                        <Column><Text text="Rating"/></Column>
                        <Column><Text text="Stock"/></Column>
                    </columns>

                    <items>
                        <ColumnListItem type="Active">
                            <cells>
                                <Text text="{productId}" />
                                <Text text="{name}" />
                                <Text text="{brand}" />
                                <Text text="₹{price}" />
                                <Text text="{rating}" />
                                <Text text="{stock}" />
                            </cells>
                        </ColumnListItem>
                    </items>

                </Table>

            </VBox>

        </Page>
    </App>

</mvc:View>
