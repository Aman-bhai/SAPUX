<mvc:View
    controllerName="sap.practice.practice.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <App id="app">

        <pages>

            <!-- Page 1 -->
            <Page id="page1" title="Page One">
                <content>

                    <Button text="Go to Page 2" press="onGoToPage2" />

                    <Button text="Get Current Page" press="onGetCurrentPage" />

                    <Button text="Add New Page" press="onAddPage" />

                    <Button text="Remove Page 2" press="onRemovePage2" />

                </content>
            </Page>

            <!-- Page 2 -->
            <Page id="page2" title="Page Two">
                <content>

                    <Button text="Back" press="onGoBack" />

                    <Button text="Back to Page 1" press="onBackToPage1" />

                    <Button text="Back to Top" press="onBackToTop" />

                </content>
            </Page>

        </pages>

    </App>

</mvc:View>