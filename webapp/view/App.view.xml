<mvc:View controllerName="sap.practice.practice.controller.App"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified">

    <App>
        <Page title="Survey Page" enableScrolling="true">
            <content>

                <FlexBox justifyContent="Center" alignItems="Start">

                    <VBox width="360px"
                        class="sapUiResponsiveContentPadding sapUiSmallMargin"
                        backgroundDesign="Solid">

                        <Title text="Survey Form" />

                        <!-- Inputs -->
                        <Label text="Username"/>
                        <Input value="{/username}" placeholder="Enter username"/>

                        <Label text="Email"/>
                        <Input value="{/email}" placeholder="Enter email"/>

                        <Label text="Password"/>
                        <Input value="{/password}" type="Password" placeholder="Enter password"/>

                        <!-- TextArea -->
                        <Label text="Feedback"/>
                        <TextArea value="{/surveyFeedback}" placeholder="Write your feedback"/>

                        <!-- Radio -->
                        <Label text="Frequency"/>
                        <RadioButtonGroup select="onFrequencyChange">
                            <buttons>
                                <RadioButton text="Daily"/>
                                <RadioButton text="Weekly"/>
                                <RadioButton text="Monthly"/>
                            </buttons>
                        </RadioButtonGroup>

                        <!-- ComboBox -->
                        <Label text="Category"/>
                        <ComboBox placeholder="Select category" selectionChange="onCategoryChange">
                            <items>
                                <core:Item key="tech" text="Technology"/>
                                <core:Item key="health" text="Health"/>
                            </items>
                        </ComboBox>

                        <!-- Select -->
                        <Label text="Priority"/>
                        <Select selectedKey="{/priority}">
                            <items>
                                <core:Item key="" text="-- Select Priority --"/>
                                <core:Item key="high" text="High"/>
                                <core:Item key="medium" text="Medium"/>
                                <core:Item key="low" text="Low"/>
                            </items>
                        </Select>

                        <!-- MultiComboBox -->
                        <Label text="Skills"/>
                        <MultiComboBox placeholder="Select skills" selectionFinish="onMultiSelect">
                            <items>
                                <core:Item key="ui5" text="SAP UI5"/>
                                <core:Item key="abap" text="ABAP"/>
                                <core:Item key="js" text="JavaScript"/>
                            </items>
                        </MultiComboBox>

                        <!-- Checkbox -->
                        <Label text="Interests"/>
                        <CheckBox text="Sports" select="onCheckBoxSelect"/>
                        <CheckBox text="Music" select="onCheckBoxSelect"/>
                        <CheckBox text="Travel" select="onCheckBoxSelect"/>

                        <!-- Date -->
                        <Label text="Date"/>
                        <DatePicker value="{/date}" placeholder="Select date"/>

                        <!-- Time -->
                        <Label text="Time"/>
                        <TimePicker value="{/time}" placeholder="Select time"/>

                        <!-- File -->
                        <Label text="Upload File"/>
                        <unified:FileUploader 
                            change="onFileChange"
                            buttonText="Browse"
                            placeholder="Choose file"/>

                        <!-- Switch -->
                        <Label text="Notifications"/>
                        <Switch state="{/notifications}" change="onSwitchChange"/>

                        <!-- Submit -->
                        <Button
                            text="Submit"
                            type="Emphasized"
                            class="sapUiMediumMarginTop"
                            press="onSubmit"/>

                    </VBox>

                </FlexBox>

            </content>
        </Page>
    </App>

</mvc:View>