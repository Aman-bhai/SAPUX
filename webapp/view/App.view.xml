<mvc:View
    controllerName="sap.practice.practice.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <VBox class="sapUiSmallMargin">

        <!-- ✅ Property Binding -->
        <Text text="Name: {/name}" />

        <!-- ✅ Two-way Binding -->
        <Input value="{/name}" liveChange=".onInputChange"/>

        <!-- ✅ Expression Binding -->
        <Text text="{= ${/age} > 18 ? 'Adult' : 'Minor' }" />

        <!-- ✅ Formatter Binding -->
        <Text text="{
            path: '/salary',
            formatter: '.formatCurrency'
        }" />

        <!-- ✅ Element Binding -->
        <Panel headerText="User Info" binding="{/}">
            <Text text="Name: {/name}" />
            <Text text="Age: {/age}" />
        </Panel>

        <!-- ✅ Aggregation Binding -->
        <List items="{/items}">
            <StandardListItem
                title="{product}"
                description="{quantity}" />
        </List>

        <!-- ✅ Button to Modify Model -->
        <Button text="Increase Salary" press=".onIncreaseSalary"/>

    </VBox>
</mvc:View>