<mvc:View
    controllerName="sap.practice.practice.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <App>
        <Page title="Tables and Lists" class="sapUiContentPadding">

            <Table items="{/products}" id="productTable"  >

                <!-- Columns -->
                <columns>
                 <Column>
                        <Text text="Product ID"/>
                    </Column>
                    <Column>
                        <Text text="Product Name"/>
                    </Column>
                    <Column>
                        <Text text="Price"/>
                    </Column>
                   
                </columns>

                <!-- Rows -->
                <items>
                    <ColumnListItem type="Active" press="onItemPress">
                        <cells>
                            <Text text="{productId}"/>
                            <Text text="{name}"/>
                            <Text text="{price}"/>
                        </cells>
                    </ColumnListItem>
                </items>

            </Table>

        </Page>
    </App>

</mvc:View>
