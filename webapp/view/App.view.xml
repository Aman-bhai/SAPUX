<mvc:View
    controllerName="sap.practice.practice.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true"
>
    <App>
        <Page title="Products">
            <content>
                <Table items="{/Products}">

                    <columns>

                        <Column>

                            <Text text="ID" />

                        </Column>


                        <Column>

                            <Text text="Name" />

                        </Column>


                    </columns>


                    <items>

                        <ColumnListItem>

                            <cells>

                                <Text text="{ID}" />

                                <Text text="{Name}" />


                            </cells>


                        </ColumnListItem>


                    </items>


                </Table>


            </content>


        </Page>


    </App>
</mvc:View>
