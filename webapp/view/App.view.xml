<mvc:View
    controllerName="sap.practice.practice.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <VBox class="sapUiSmallMargin">

        <!-- USER INPUT -->
        <Input 
            value="{/name}" 
            placeholder="Enter your name" />

        <!-- FORMATTER OUTPUT -->
        <Text text="{
            path: '/name',
            formatter: '.formatter.formatName'
        }" />

    </VBox>

</mvc:View>
