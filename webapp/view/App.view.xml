<mvc:View controllerName="sap.practice.practice.controller.App"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <App id="app">
        <Page title="Login Page" enableScrolling="false">
            <content>

                <!-- FlexBox to center everything -->
                <FlexBox 
                    height="100%" 
                    justifyContent="Center" 
                    alignItems="Center">

                    <!-- Login Card -->
                    <VBox 
                        width="300px"
                        class="sapUiSmallMargin sapUiResponsiveContentPadding sapUiTinyMargin"
                        backgroundDesign="Solid"
                    >

                        <Title text="Login" level="H3" class="sapUiSmallMarginBottom"/>

                        <Label text="Username"/>
                        <Input id="username" placeholder="Enter your username"/>

                        <Label text="Email" class="sapUiSmallMarginTop"/>
                        <Input id="emailInput" placeholder="Enter your email"/>

                        <Label text="Password" class="sapUiSmallMarginTop"/>
                        <Input id="password" type="Password" placeholder="Enter your password"/>

                        <Button 
                            text="Login" 
                            type="Emphasized"
                            class="sapUiSmallMarginTop"
                            press="onLoginPress"/>

                            <Text text="Don't have an account?" class="sapUiSmallMarginTop"/>
                            <Button 
                                text="Register" 
                                type="default"
                                press="onRegisterPress"/>   

                    </VBox>

                </FlexBox>

            </content>
        </Page>
    </App>
</mvc:View>