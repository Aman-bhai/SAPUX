<mvc:View
    controllerName="sap.practice.practice.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:table="sap.ui.table">

    <App>
        <Page title="Product Catalog" class="sapUiContentPadding">

            <VBox class="sapUiSmallMargin">

                <!-- 🔍 Search -->
                <SearchField 
                    placeholder="Search products" 
                    liveChange=".onSearch" />

                <!-- 🎯 Filter -->
                <Select change=".onFilterCategory" selectedKey="All">
                    <items>
                        <core:Item key="All" text="All Brands"/>
                        <core:Item key="Apple" text="Apple"/>
                        <core:Item key="Samsung" text="Samsung"/>
                        <core:Item key="Sony" text="Sony"/>
                        <core:Item key="Dell" text="Dell"/>
                    </items>
                </Select>

                <!-- 🔃 Sort -->
                <Button 
                    text="Sort by Price" 
                    press=".onSortByPrice"
                    type="Emphasized"/>

                <!-- 🔘 CRUD -->
                <HBox class="sapUiSmallMarginTop">
                    <Button text="Add" press=".onAddProduct" type="Accept"/>
                    <Button text="Update" press=".onUpdateProduct"/>
                    <Button text="Delete" press=".onDeleteProduct" type="Reject"/>
                </HBox>

                <!-- 📦 GRID TABLE -->
                <table:Table
                    id="yourTableId"
                    rows="{/products}"
                    selectionMode="Single"
                    visibleRowCount="6">

                    <table:columns>

                        <table:Column>
                            <Label text="ID"/>
                            <table:template>
                                <Text text="{productId}"/>
                            </table:template>
                        </table:Column>

                        <table:Column>
                            <Label text="Name"/>
                            <table:template>
                                <Text text="{name}"/>
                            </table:template>
                        </table:Column>

                        <table:Column>
                            <Label text="Brand"/>
                            <table:template>
                                <Text text="{brand}"/>
                            </table:template>
                        </table:Column>

                        <table:Column>
                            <Label text="Price"/>
                            <table:template>
                                <Text text="₹{price}"/>
                            </table:template>
                        </table:Column>

                    </table:columns>

                </table:Table>

            </VBox>
        </Page>
    </App>
</mvc:View>