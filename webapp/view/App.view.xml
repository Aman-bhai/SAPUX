<mvc:View
    controllerName="sap.practice.practice.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <App>
        <Page title="Fragments" class="sapUiContentPadding">

          <VBox>

    <HBox alignItems="Center" justifyContent="Start" spacing="10px">

        <Button 
            text="Open Dialog" 
            press=".onOpenDialog" 
            type="Emphasized" 
    class="sapUiSmallMarginEnd"/>


        <Button 
            text="Close Dialog" 
            press=".onCancel" 
            type="Reject" class="sapUiSmallMarginEnd"/>


        <Button 
            text="Open Popover" 
            press=".onOpenPopover"  class="sapUiSmallMarginEnd"
            type="Accept"/>


 <Button 
            text="Open Message Box" 
            press=".onOpenMessageBox"   class="sapUiSmallMarginEnd"
            type="Attention"/>


    </HBox>

</VBox>
</Page>
    </App>

</mvc:View>